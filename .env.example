# ══════════════════════════════════════════════════════════════
# Smart Grid Security Monitoring — Environment Configuration
# Kelompok 3 — Keamanan Data dan Aplikasinya
# ══════════════════════════════════════════════════════════════
# Copy file ini menjadi .env lalu sesuaikan nilainya.
# Semua nilai di bawah adalah DEFAULT yang sudah bisa dipakai langsung.
# ══════════════════════════════════════════════════════════════

# ── PORT KONFIGURASI ─────────────────────────────────────────
GENERATOR_PORT=5050
API_SERVER_PORT=8001

# ── URL KONFIGURASI ──────────────────────────────────────────
# URL SSE endpoint dari Data Generator (dibaca oleh ML Pipeline)
STREAM_URL=http://localhost:5050/data/realtime
GENERATOR_PORT=5055
GENERATOR_RATE=10

NGROK_ENABLED=false
NGROK_TOKEN=

# URL POST endpoint dari API Server (dibaca oleh ML Pipeline)
PREDICTION_POST_URL=http://localhost:8001/prediction/receive

# URL SSE endpoint dari API Server (dibaca oleh Dashboard)
SSE_URL=http://localhost:8001/prediction/stream

# ── PYTHON ENCODING (Windows) ────────────────────────────────
PYTHONIOENCODING=utf-8
